# ── Meeting Copilot — environment ────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env or any *service_acc*.json.

# Required: Google AI Studio key for Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Model routing (override defaults from core/models.py if you like) ──
# Deep/high-accuracy answers:
GEMINI_MODEL_PRO=gemini-3-pro-preview
# Fast streaming drafts + notes:
GEMINI_MODEL_FLASH=gemini-2.5-flash
# Optional cloud STT (only used when STT_BACKEND=gemini_live):
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# ── STT ──
# local  = RealtimeSTT/faster-whisper (default, lowest latency, private)
# gemini_live = Gemini Live cloud STT (multilingual/high accuracy, 15-min cap)
STT_BACKEND=local
# local model tier: fast=tiny.en, balanced=small.en, accurate=base.en / distil-large-v3
STT_MODE=balanced

# ── Server ──
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ── RAG ──
CHROMA_DB_PATH=./chroma_db

# ── Optional TTS (voice-agent use cases only; OFF in meeting mode) ──
# TTS_ENABLED=false
# CARTESIA_API_KEY=
